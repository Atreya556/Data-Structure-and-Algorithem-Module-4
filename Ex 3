#Implement a Stack based Queue
class StackBasedQueue:
    def __init__(self):
        self._InboundStack = Stack()   
        self._OutboundStack = Stack()  

    def __repr__(self):
        plural = '' if self._size == 1 else 's'
        # Elements in queue order: OutboundStack reversed + InboundStack
        values = [str(c) for c in self._OutboundStack][::-1] + [str(c) for c in self._InboundStack]
        return f'<StackBasedQueue ({self._size} element{plural}): [{", ".join(values)}]>'

    def enqueue(self, data):
        """
        Add an element to the end of the queue
        """
        self._InboundStack.push(data)
        self._size += 1

    def dequeue(self):
        """
        Remove an element from the front of the queue
        """
        if len(self._OutboundStack) == 0:
            # Transfer all elements from InboundStack to OutboundStack
            while len(self._InboundStack) > 0:
                self._OutboundStack.push(self._InboundStack.pop())

        if len(self._OutboundStack) == 0:
            return None  # queue is empty

        self._size -= 1
        return self._OutboundStack.pop()